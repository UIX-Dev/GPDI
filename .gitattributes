# 기본: 모든 텍스트 파일은 자동 감지, 저장소 안에는 LF로 저장
* text=auto eol=lf

# 명시적 텍스트 (LF)
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.svg    text eol=lf
*.txt    text eol=lf
*.xml    text eol=lf

# 바이너리 (변환 금지)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
*.pdf    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.zip    binary
